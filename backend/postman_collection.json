{
  "info": {
    "name": "Artisan AI API",
    "description": "API collection for Artisan AI platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('token', response.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@artisanai.com\",\n  \"password\": \"admin123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current Admin",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Artisans",
      "item": [
        {
          "name": "List Artisans",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/artisans?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "artisans"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "status",
                  "value": "verified",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Create Artisan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Artisan\",\n  \"phone\": \"+919999999999\",\n  \"whatsappNumber\": \"+919999999999\",\n  \"email\": \"test@example.com\",\n  \"craftType\": \"Pottery\",\n  \"region\": \"Rajasthan\",\n  \"language\": \"hindi\",\n  \"bio\": \"Expert potter with 20 years experience\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/artisans",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "artisans"]
            }
          }
        },
        {
          "name": "Get Artisan",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/artisans/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "artisans", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Verify Artisan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"ID verified, craft samples reviewed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/artisans/:id/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "artisans", ":id", "verify"],
              "variable": [
                {
                  "key": "id",
                  "value": ""
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?page=1&limit=24",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "24"
                },
                {
                  "key": "craftType",
                  "value": "Metal Craft",
                  "disabled": true
                },
                {
                  "key": "region",
                  "value": "Kerala",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Product (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Verify Product (QR)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/verify/:productId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "verify", ":productId"],
              "variable": [
                {
                  "key": "productId",
                  "value": "ART-KER-MET-001"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
